width: auto%; height: autopx;\"\u003e5.3, A2DP, LE,\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eUSB\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eUSB Type-C 3.2, OTG\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eWLAN\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eWi-Fi 802.11 a\/b\/g\/n\/ac\/6e, dual-band, Wi-Fi Direct\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eNFC\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eYes\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eSensor\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eFingerprint (under-display, optical) | accelerometer | gyro | Proximity | Compass | Barometer\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eBattery Capacity\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eLi-Ion 5000mAh, non-removable\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e45W wired, PD3.0, 65% in 30 min (adverticed)\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e15W Wireless\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e4.5W Reverse Wireless\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eDimension\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e162.3 x 79 x 8.6 mm\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eColour\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eTitanium Gray | Titanium Black | Titanium Violet | Titanium Blue |  Titanium Yellow | Titanium Orange\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eWeight\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e232g\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr style=\"height: autopx;\"\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003eIn The Box\u003c\/td\u003e\n\u003ctd style=\"width: auto%; height: autopx;\"\u003e‎Handset | SIM Tray Ejector | Data Cable | User Guide\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003c\/tbody\u003e\n\u003c\/table\u003e\n"};


var $spinURL =
    SirvSpinsPath.replace(/{product\-id}/g, SirvProductID)
    .replace(/{product\-sku}/g, SirvProductSKU)
    .replace(/{vendor}/g, SirvProductVendor)
    .replace(/{vendor_no_space}/g, SirvProductVendorNoSpace)
    .replace(/{product\-name}/g, SirvProductName)
    .replace(/{product\-title}/g, SirvProductName);

if (typeof SirvSpinOverrides != 'undefined' && typeof SirvSpinOverrides[SirvProductID + '-' + currentVariantID] != 'undefined' && SirvSpinOverrides[SirvProductID + '-' + currentVariantID] != '') {
    $spinURL = SirvSpinOverrides[SirvProductID + '-' + currentVariantID].replace(/^\//gmi, '');

}

if (typeof SirvCache != 'undefined' && typeof SirvCache[$spinURL] != 'undefined' && SirvSpinPosition == 'first') {
    var $slidesContainer = document.querySelector('.MagicToolboxSlides');
    if ($slidesContainer) {
        $slidesContainer.querySelector('.MagicToolboxSlide.active-magic-slide').setAttribute('class', 'MagicToolboxSlide')
        $slidesContainer.querySelector('.MagicToolboxSlide[data-slide-id="spin"]').setAttribute('class', 'MagicToolboxSlide active-magic-slide')
    }
    var $smv = document.getElementById('sirv-spin');
    if ($smv) {
      $smv.setAttribute('data-options','');
    } 
}

var $SirvItems = document.querySelectorAll('#sirv-spin > div[data-id]');
if ($SirvItems) {
  $SirvItems.forEach(function($elm){
    $elm.setAttribute( 'data-id', $elm.getAttribute('data-id').replace(/[^a-zA-Z0-9]/gmi,'') )
  })
}

</script>

